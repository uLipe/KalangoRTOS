# Build artifacts
*.elf
*.bin
*.hex
*.map
*.lst

# Build directories — matched recursively anywhere in the tree
**/build/

# SDK consumer e2e test output (built SDK tree + linked app)
tests/**/_out/

# Unit test binaries (host-compiled)
tests/*_unit/*_unit_test

# Integration test kernel static library (built per test dir)
tests/**/integ_kernel/
tests/**/libtest_kernel.a

# TSIM simulation artefacts
Sim.out
Sim64.out
Sim.traceinstr
Sim.tracepc
Sim.tracejmps
Sim.tracels
IConfig
MConfig
OConfig
PConfig
*.tsim

# Python
__pycache__/
*.pyc
*.pyo

# CMake generated files — recursive so they are caught in any subdirectory
**/CMakeCache.txt
**/CMakeFiles/
**/cmake_install.cmake
**/install_manifest.txt
**/CTestTestfile.cmake

.cursor/
.ulmk/

# Internal personal design notes — kept locally, not tracked
docs/microkernel_book_tricore.md
build-riscv/
