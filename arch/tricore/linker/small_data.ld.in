/* arch/tricore/linker/small_data.ld.in
 * Layer 2 — arch-owned, TriCore-specific.
 * Included by generate_ld.py when HAVE_SMALL_DATA = 1 in the chip memory.ld.
 *
 * TriCore ABI uses A0/A8 for mutable small data (.sdata/.sbss, window based
 * on KERNEL_RAM) and A1/A9 for read-only small data (.sdata2/.sbss2, window
 * based on KERNEL_FLASH).
 *
 * Anchors use ORIGIN() rather than ADDR() so that empty sections (--gc-sections
 * discards them when no code uses small-data globals) do not cause "could not
 * find output section" linker errors.  The +0x8000 offset centres the anchor
 * in the 64 KiB signed window reachable by LD/ST short encodings.
 *
 * .sdata  — small mutable data, placed in KERNEL_RAM with LMA in KERNEL_FLASH
 *           (startup.S copies .sdata just like .kernel_data).
 * .sbss   — small zero-init data, NOLOAD in KERNEL_RAM.
 * .sdata2 — small read-only data, placed directly in KERNEL_FLASH (no copy).
 * .sbss2  — small zero-init read-only (rare, treated as .sbss).
 */

    .sdata  : { *(.sdata  .sdata.*)  } > KERNEL_RAM AT > KERNEL_FLASH
    .sbss   (NOLOAD) : { *(.sbss   .sbss.*)   } > KERNEL_RAM
    .sdata2 : { *(.sdata2 .sdata2.*) } > KERNEL_FLASH
    .sbss2  (NOLOAD) : { *(.sbss2  .sbss2.*)  } > KERNEL_RAM

    _small_data_  = ORIGIN(KERNEL_RAM)   + 0x8000;   /* → A0, A8 */
    _small_data2_ = ORIGIN(KERNEL_FLASH) + 0x8000;   /* → A1, A9 */
    _small_data3_ = ORIGIN(KERNEL_RAM)   + 0x8000;
    _small_data4_ = ORIGIN(KERNEL_FLASH) + 0x8000;
