/* linker/kernel/kernel_data.ld.in
 * Layer 1 — kernel-owned, arch-independent.
 * Kernel mutable state split into two sections:
 *   .kernel_data — initialised variables, LMA-backed (flash → RAM copy)
 *   .kernel_bss  — zero-initialised variables, NOLOAD (startup.S zeroes)
 *
 * Both sections are aligned to ULMK_MPU_ALIGN on both ends so the arch may
 * optionally configure a single supervisor-only DPR range covering the
 * combined kernel data/bss area.
 *
 * startup.S protocol:
 *   1. Copy [__ulmk_kernel_data_load .. __ulmk_kernel_data_load + size) → RAM
 *      using _ulmk_kernel_data_start / _ulmk_kernel_data_end.
 *   2. Zero [_ulmk_kernel_bss_start .. _ulmk_kernel_bss_end).
 */

    __ulmk_kernel_data_load = LOADADDR(.kernel_data);
    .kernel_data : ALIGN(ULMK_MPU_ALIGN) {
        _ulmk_kernel_data_start = .;
        *(.data.ulmk_arch_*)
        *(.data.ulmk_kernel_*)
        *(.data.ulmk_sched_*)
        *(.data.ulmk_ipc_*)
        *(.data.ulmk_irq_*)
        *(.data.ulmk_mem_*)
        *(.data.ulmk_notif_*)
        *(.data .data.*)
        *(.sdata .sdata.*)
        /*
         * -fdata-sections creates one named section per global variable
         * (e.g. .g_preempt_old_ctx) rather than .data.varname.  These
         * sections are not matched by any pattern above.  By this point
         * .text* and .rodata* have been consumed by kernel_text, so the
         * catch-all below only pulls in writable (and small-const) orphans.
         */
        *(*)
        . = ALIGN(4);
        _ulmk_kernel_data_end = .;
    } > KERNEL_RAM AT > KERNEL_FLASH

    .kernel_bss (NOLOAD) : ALIGN(4) {
        _ulmk_kernel_bss_start = .;
        *(.bss.ulmk_arch_*)
        *(.bss.ulmk_kernel_*)
        *(.bss.ulmk_sched_*)
        *(.bss.ulmk_ipc_*)
        *(.bss.ulmk_irq_*)
        *(.bss.ulmk_mem_*)
        *(.bss.ulmk_notif_*)
        *(.bss .bss.*)
        *(COMMON)
        . = ALIGN(4);
        _ulmk_kernel_bss_end = .;
    } > KERNEL_RAM
