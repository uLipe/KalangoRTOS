/* linker/kernel/kernel_text.ld.in
 * Layer 1 — kernel-owned, arch-independent.
 * Kernel executable code and read-only data.
 *
 * ALIGN(32) at the start for TriCore fetch granularity.  ALIGN(ULMK_MPU_ALIGN)
 * at the end so CPR 0 (programmed from _ulmk_kernel_exec_*) covers every
 * instruction in the section — an unaligned end leaves a hole at the tail.
 *
 * Input sections are selected exclusively from the kernel static library
 * (libulmk_kernel.a) so that component code is never mixed in here.
 * Startup and vector object files are handled earlier in vectors.ld.in via
 * KEEP() rules and do not appear in .kernel_text.
 */

    .kernel_text : ALIGN(32) {
        _ulmk_kernel_text_start = .;
        /*
         * Include bare .text as well as .text.* — RISC-V/ARM asm stubs use
         * `.text` (e.g. ctx_switch trampolines with mret).  Leaving them to
         * .user_runtime makes mret fetchable from U-mode (illegal tin=2).
         */
        *libulmk_kernel.a:(.text .text.* .rodata.* .rodata)
        . = ALIGN(ULMK_MPU_ALIGN);
        _ulmk_kernel_text_end = .;
        _ulmk_kernel_exec_end = .;
    } > KERNEL_FLASH
