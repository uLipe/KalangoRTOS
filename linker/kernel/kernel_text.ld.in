/* linker/kernel/kernel_text.ld.in
 * Layer 1 — kernel-owned, arch-independent.
 * Kernel executable code and read-only data.
 *
 * Not MPU-aligned: the kernel runs in supervisor mode and does not need
 * a protection range for its own code.  ALIGN(32) satisfies TriCore's
 * 32-byte instruction fetch granularity.
 *
 * Input section patterns match the naming conventions for kernel and arch
 * internal functions (all prefixed ulmk_arch_*, ulmk_kernel_*, etc.).
 */

    .kernel_text : ALIGN(32) {
        _ulmk_kernel_text_start = .;
        *(.text.ulmk_arch_*)
        *(.text.ulmk_kernel_*)
        *(.text.ulmk_sched_*)
        *(.text.ulmk_ipc_*)
        *(.text.ulmk_irq_*)
        *(.text.ulmk_mem_*)
        *(.text.ulmk_notif_*)
        *(.text .text.*)
        *(.rodata .rodata.*)
        _ulmk_kernel_text_end = .;
    } > KERNEL_FLASH
