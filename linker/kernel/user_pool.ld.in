/* linker/kernel/user_pool.ld.in
 * Layer 1 — kernel-owned, arch-independent.
 * Physical allocator pool: the remaining KERNEL_RAM after all static
 * sections have been placed.
 *
 * ulmk_arch_phys_alloc_init() receives these symbols at boot and manages
 * the range as a simple first-fit allocator.  Thread stacks and anonymous
 * ulmk_mem_map() regions are carved from here.
 *
 * Always the last section in KERNEL_RAM so it expands to the end.
 */

    .user_pool (NOLOAD) : ALIGN(ULMK_MPU_ALIGN) {
        _ulmk_user_pool_start = .;
        . = ORIGIN(KERNEL_RAM) + LENGTH(KERNEL_RAM);
        _ulmk_user_pool_end = .;
    } > KERNEL_RAM
