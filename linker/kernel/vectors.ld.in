/* linker/kernel/vectors.ld.in
 * Layer 1 — kernel-owned, arch-independent.
 * Trap vector table and interrupt vector table sections.
 *
 * Both require 256-byte alignment so the hardware base-address register
 * field encodes the address without bit manipulation.
 *
 * If HAVE_BMHD is set in the chip memory.ld, generate_ld.py inserts the
 * chip-provided bmhd.ld.in before this fragment.
 *
 * .startup must be the very first section in KERNEL_FLASH so that the CPU
 * reset address (0x80000000 on TC2xx/TC3xx without BMHD) lands on _start,
 * not on the trap table.  QEMU with -kernel also starts from 0x80000000
 * rather than the ELF e_entry field.
 */

    .startup : {
        KEEP(*(.text._start))
    } > KERNEL_FLASH

    .trap_table : ALIGN(256) {
        _ul_trap_table = .;
        KEEP(*(.trap_table))
    } > KERNEL_FLASH

    .int_table : ALIGN(256) {
        _ul_int_table = .;
        KEEP(*(.int_table))
    } > KERNEL_FLASH
